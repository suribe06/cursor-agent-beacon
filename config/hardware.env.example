# VIEWE UEDX48480021-MD80E — copy to .env or export before running the bridge
#
# Linux USB-CDC (typical): /dev/ttyACM0
# List ports: ls /dev/ttyACM* /dev/ttyUSB*

CURSOR_AGENT_BEACON_HTTP_URL=http://127.0.0.1:8765/status
CURSOR_AGENT_BEACON_SERIAL_PORT=/dev/ttyACM0
CURSOR_AGENT_BEACON_SERIAL_BAUD=115200
CURSOR_AGENT_BEACON_THEME=standard
CURSOR_AGENT_BEACON_THEMES_DIR=themes
