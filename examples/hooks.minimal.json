{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "python3 /path/to/cursor-agent-beacon/.cursor/hooks/hook-handler.py",
        "timeout": 5
      }
    ],
    "afterShellExecution": [
      {
        "command": "python3 /path/to/cursor-agent-beacon/.cursor/hooks/hook-handler.py",
        "timeout": 5
      }
    ],
    "afterAgentThought": [
      {
        "command": "python3 /path/to/cursor-agent-beacon/.cursor/hooks/hook-handler.py",
        "timeout": 5
      }
    ],
    "afterAgentResponse": [
      {
        "command": "python3 /path/to/cursor-agent-beacon/.cursor/hooks/hook-handler.py",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": "python3 /path/to/cursor-agent-beacon/.cursor/hooks/hook-handler.py",
        "timeout": 5
      }
    ]
  }
}
